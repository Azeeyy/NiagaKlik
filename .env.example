# ============================================================================
# NiagaKlik - Environment Variables
# ============================================================================
# Copy file ini ke .env.local atau set di dashboard Vercel
# ----------------------------------------------------------------------------

# =====================
# MongoDB Atlas
# =====================
# Format SRV (default):
#   MONGODB_URI=mongodb+srv://username:password@cluster.xxxxx.mongodb.net/niagaklik?retryWrites=true&w=majority
# Format non-SRV (jika DNS SRV diblokir jaringan):
#   MONGODB_URI=mongodb://host1:27017,host2:27017,host3:27017/niagaklik?ssl=true&replicaSet=xxx-shard-0&authSource=admin&retryWrites=true&w=majority
MONGODB_URI=

# =====================
# JWT Secret
# =====================
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# =====================
# Resend (Email OTP & Reset Password)
# =====================
# Daftar: https://resend.com -> Create API Key -> Set verified domain
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=NiagaKlik <noreply@niagaklik.com>

# =====================
# Uploadthing (File Uploads - WAJIB)
# =====================
# Daftar: https://uploadthing.com -> Create App -> Copy Secret & App ID
# Untuk upload gambar produk & avatar user
UPLOADTHING_SECRET=sk_live_xxxxxxxxxxxx
UPLOADTHING_APP_ID=xxxxxxxx

# =====================
# Google Maps (Opsional)
# =====================
# Daftar: https://console.cloud.google.com -> Aktifkan Maps JS API + Places API -> Buat API Key
# Untuk autocomplete alamat di halaman dashboard/address
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
